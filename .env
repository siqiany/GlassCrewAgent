OPENAI_API_BASE= YOUR_OPENAI_API_BASE
OPENAI_API_KEY= YOUR_OPENAI_API_KEY
MODEL_NAME=YOUR_MODEL_NAME
CREWAI_TRACING_ENABLED=true

DASHSCOPE_NAME=YOUR_DASHSCOPE_NAME
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY

DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
EMBEDDING_NAME=text-embedding-v2
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=YOUR_EMBEDDING_API_KEY

MP_KEY=YOUR_MP_KEY
# =============================================================================
# Supercomputing Internet (scnet.cn) VASP Calculation Configuration
# =============================================================================
# SSH connection settings
SUPERCOMPUTING_HOST=cancon.hpccube.com
SUPERCOMPUTING_PORT=YOUR_SUPERCOMPUTING_PORT
SUPERCOMPUTING_USERNAME=YOUR_SUPERCOMPUTING_USERNAME
SUPERCOMPUTING_PRIVATE_KEY_PATH=YOUR_SUPERCOMPUTING_PRIVATE_KEY_PATH

# VASP module (as required by Supercomputing Internet)
VASP_MODULE_NAME=vasp-5.4.4-ioptcell_intelmpi2017_hdf5_libxc

# Base directory for VASP jobs - each job gets its own timestamped subdirectory
VASP_JOBS_REMOTE_DIR=~/myjob

# Legacy: Original case directory from app market (kept for reference)
# VASP_REMOTE_DIR=~/apprepo/vasp/vasp-5.4.4-ioptcell_intelmpi2017_hdf5_libxc/case

# pymatgen VASP configuration - REQUIRED
# You must set this to your POTCAR (pseudopotential) directory
PMG_VASP_PSP_DIR=CHANGE_ME_TO_YOUR_POTCAR_DIRECTORY
